{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["chrome"]
  },
  "include": ["shared/**/*", "background/**/*", "popup/**/*", "options/**/*"],
  "exclude": ["node_modules", "dist", "server"]
}
