{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
         {
      "type": "node",
      "request": "launch",
      "name": "Launch Express via ts-node",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start-server" // or whatever your start script name is in package.json
      ],
      "port": 9229,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outputCapture": "std",
      "cwd": "${workspaceFolder}"
    }
    ]
}