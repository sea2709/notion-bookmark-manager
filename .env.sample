# Notion Integration
# Create an internal integration at https://www.notion.so/profile/integrations
NOTION_INTERNAL_INTEGRATION_SECRET=

# Also used by MCP (mcp-remote) for search via Gemini
NOTION_API_KEY=

# Notion Database IDs
# Found in the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_BOOKMARKS_DATABASE_ID=
NOTION_FOLDERS_DATABASE_ID=

# Google Gemini AI (used for search)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.5-flash
